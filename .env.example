# Copia este archivo como .env y ajusta los valores según tu entorno
# cp .env.example .env

# Entorno de despliegue (dev, staging, prod)
ENVIRONMENT=dev

# Región de AWS
AWS_REGION=us-east-1

# Perfil de AWS (~/.aws/credentials)
AWS_PROFILE=dev

# Contraseña inicial de la base de datos RDS (sensible — no commitear)
DB_PASSWORD=change-me-before-apply

# Identidad de email verificada en SES (remitente para envío de correos)
SES_EMAIL_IDENTITY=noreply@dev.cloudflax.com
