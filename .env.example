# Copia este archivo a .env y ajusta los valores según tu entorno
# cp .env.example .env

ENVIRONMENT=dev
AWS_REGION=us-east-1

# Credenciales AWS (consola IAM → User → Create access key)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Perfil AWS (~/.aws/credentials). Con credenciales de arriba, déjalo comentado
# AWS_PROFILE=dev

# Contraseña RDS (sensible, no commitear)
DB_PASSWORD=

# ARN del secret de la DB en Secrets Manager (tras desplegar con Terraform)
DB_SECRET_ARN=

# Identidad SES (remitente verificado para envío de correos)
SES_EMAIL_IDENTITY=noreply@dev.cloudflax.com
